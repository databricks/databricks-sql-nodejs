# Set the default behavior, in case users don't have core.autocrlf set.
#
* text=auto

# Files that should always be normalized and converted to native line
# endings on checkout.
#
*.js text
*.json text
*.yml text
*.xml text
*.ts text
*.md text
*.sh text eol=lf
*.conf text
*.thrift text
*.properties text
LICENSE text
Makefile text
Dockerfile* text

# Files that are truly binary and should not be modified.
#
*.pem binary
*.crt binary
*.key binary
*.jks binary
*.p12 binary

# Exclude files from exporting.
#
.gitattributes export-ignore
.gitignore     export-ignore

# napi-rs auto-generates this file from the kernel's `napi-binding/napi/`
# crate; regenerated by `npm run build:native`. Tell git/GitHub it's
# machine-generated so it collapses in diffs and is excluded from
# blame and language stats.
native/sea/index.d.ts linguist-generated=true
